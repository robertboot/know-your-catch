{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Know Your Catch regulations feed (v1)",
  "type": "object",
  "required": ["schema", "jurisdiction", "effectiveYear", "verifiedDate", "rules"],
  "properties": {
    "schema": { "const": "kyc-regulations/v1" },
    "jurisdiction": { "enum": ["fed_gulf", "al_state", "fl_state", "ms_state", "la_state", "tx_state"] },
    "jurisdictionName": { "type": "string" },
    "agency": { "type": "string" },
    "authority": { "type": "string" },
    "effectiveYear": { "type": "integer", "minimum": 2024 },
    "verifiedDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "universalGearNote": { "type": "string" },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["open", "verified", "confidence", "source", "lastUpdated"],
        "properties": {
          "open": { "type": "string", "minLength": 1 },
          "minSize": { "type": ["number", "null"] },
          "maxSize": { "type": ["number", "null"] },
          "lengthType": { "type": ["string", "null"], "enum": ["TL", "FL", "CFL", "LJFL", null] },
          "bagLimit": { "type": ["integer", "null"] },
          "vesselLimit": { "type": ["integer", "null"] },
          "notes": { "type": "string" },
          "verified": { "type": "boolean" },
          "confidence": { "type": "string", "enum": ["verified", "partial", "closure_confirmed_reopen_pending", "unconfirmed", "not_managed"] },
          "source": { "type": "string", "format": "uri" },
          "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    }
  }
}
