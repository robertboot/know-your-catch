{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Know Your Catch photo manifest (v1)",
  "type": "object",
  "required": ["schema", "species"],
  "properties": {
    "schema": { "const": "kyc-photos/v1" },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "note": { "type": "string" },
    "species": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "primary"],
        "properties": {
          "name": { "type": "string" },
          "primary": { "enum": ["proprietary", "fallback", "none"] },
          "proprietary": { "type": ["string", "null"] },
          "fallback": {
            "type": ["object", "null"],
            "required": ["url", "credit", "license"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "credit": { "type": "string" },
              "license": { "type": "string" }
            }
          },
          "updated": { "type": "string" }
        }
      }
    }
  }
}
