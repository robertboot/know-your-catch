{
  "name": "reelintel",
  "private": true,
  "version": "1.0.0-beta.1",
  "type": "module",
  "description": "ReelIntel — identify your catch, check the rules, log it, find better spots. Built for the Gulf of America.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate-feeds": "node regulations/validate.mjs",
    "validate-photos": "node photos/validate.mjs",
    "ios:init": "cap add ios && npm run ios:sync",
    "ios:build": "KYC_BASE=./ KYC_ADMIN=false vite build",
    "ios:sync": "npm run ios:build && cap sync ios",
    "ios:assets": "capacitor-assets generate --ios",
    "ios:prepare": "bash scripts/ios-prepare.sh",
    "ios:ship": "bash scripts/ios-ship.sh",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "exifr": "^7.1.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.10"
  }
}
